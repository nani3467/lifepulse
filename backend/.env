FLASK_ENV=development
SECRET_KEY=lifepulse-super-secret-change-this-in-production
JWT_SECRET_KEY=lifepulse-jwt-secret-change-this-in-production

# MySQL (comment out if using SQLite for dev)
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/lifepulse_db
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_DB=lifepulse_db

# SQLite used by default in development (no setup needed)
UPLOAD_FOLDER=./uploads
PORT=5000
